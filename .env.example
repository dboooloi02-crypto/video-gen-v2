# Copy to .env and fill in your keys

# LLM (ZhipuAI / OpenAI / DeepSeek — any OpenAI-compatible)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash

# Template
DEFAULT_TEMPLATE=english_learning

# Whisper (optional, for accurate word timing)
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
